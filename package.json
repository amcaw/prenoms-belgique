		"@types/d3-shape": "^3.1.8",
		"d3-array": "^3.2.4",
		"d3-geo": "^3.1.1",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
